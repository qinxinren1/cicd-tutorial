# Copy to ~/.jobpilot/searches.yaml and adjust.

defaults:
  location: "Netherlands"
  distance: 1000
  hours_old: 240
  # 0 = as many as JobSpy can return per search (~1000 cap); omit for default 25.
  results_per_site: 0
  experience_level: ['junior', 'graduate', 'entry-level']

locations:
  - location: "Netherlands"
    remote: false

queries:
  - query: "Software Engineer"
    tier: 1
  - query: "Traineeship"
    tier: 1
  - query: "AI Engineer"
    tier: 1

# Optional: override default database path (~/.jobpilot/jobs.db).
# database_path: /custom/path/jobs.db
